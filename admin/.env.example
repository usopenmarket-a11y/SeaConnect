# SeaConnect Admin portal (Next.js) — environment variables
# Copy this file to .env.local for local development.
# For UAT/prod, set these in Vercel's Environment Variables dashboard.
# NEVER commit .env.local to version control.

# ===========================================================================
# API endpoints
# ===========================================================================

# Public API URL — injected into browser bundles at build time by Next.js.
# Dev:  http://localhost:8010   (Docker Compose host port for the Django API)
# UAT:  https://seaconnect-uat-api.onrender.com
# Prod: https://api.seaconnect.app
NEXT_PUBLIC_API_URL=http://localhost:8010

# Internal API URL — used by Next.js Server Components and Route Handlers
# running inside the same Docker network. Never exposed to the browser.
# Dev: http://api:8000   (Docker Compose internal service name)
# UAT/Prod: same as NEXT_PUBLIC_API_URL (Vercel uses public URL for SSR)
API_INTERNAL_URL=http://api:8000
