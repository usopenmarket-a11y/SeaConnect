# SeaConnect backend environment variables — copy to .env and fill in values.
# Never commit the real .env file to version control.

# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://seaconnect:seaconnect@localhost:5432/seaconnect

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# JWT key paths (RS256) — generate with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem

# Email (Mailpit in dev)
EMAIL_HOST=localhost
EMAIL_PORT=1025
DEFAULT_FROM_EMAIL=noreply@seaconnect.local

# MinIO / S3 storage
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=seaconnect
AWS_S3_ENDPOINT_URL=http://localhost:9000

# Fawry payment gateway
FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=
FAWRY_BASE_URL=https://atfawry.fawrystaging.com

# Firebase Cloud Messaging (FCM)
# Encode your Firebase service account JSON with:
#   base64 -w 0 service-account.json
# Then paste the result here.
FIREBASE_CREDENTIALS_JSON=  # base64-encoded Firebase service account JSON

# Ollama (local AI — dev only)
OLLAMA_BASE_URL=http://localhost:11434
