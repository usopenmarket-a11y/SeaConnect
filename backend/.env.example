# SeaConnect backend environment variables
# Copy this file to .env (dev) or configure directly in Render (UAT/prod).
# NEVER commit a file containing real secrets to version control.
#
# Variable groups are ordered by priority: Django core → DB → cache → storage
# → email → auth → payments → integrations → observability.

# ===========================================================================
# Django core
# ===========================================================================

# A cryptographically random 50-character string.
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-50-char-random-string

# Settings module to load. Use config.settings.dev locally; config.settings.uat on Render.
DJANGO_SETTINGS_MODULE=config.settings.dev

# Set to False in UAT/prod. True only in local dev.
DEBUG=True

# Comma-separated hostnames Django will serve. Render sets this automatically via render.yaml.
ALLOWED_HOSTS=localhost,127.0.0.1

# ===========================================================================
# Database (Supabase PostgreSQL in UAT, local Docker in dev)
# ===========================================================================

# Dev default uses the Docker Compose "db" service hostname.
# UAT: postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://sc_user:localpassword@db:5432/seaconnect_dev

# ===========================================================================
# Redis / Celery (Redis Cloud in UAT, local Docker in dev)
# ===========================================================================

# Dev default uses the Docker Compose "redis" service hostname.
# UAT: redis://default:[password]@[host]:[port]/0
REDIS_URL=redis://redis:6379/0

# ===========================================================================
# Storage — Cloudflare R2 (S3-compatible, free tier 10 GB)
# Set USE_S3=True in UAT/prod. Leave False for dev (uses local filesystem).
# ===========================================================================

USE_S3=False

# R2 access key (found in Cloudflare dashboard → R2 → Manage R2 API tokens)
AWS_ACCESS_KEY_ID=your-r2-access-key-id

# R2 secret key
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Bucket name created in Cloudflare R2
AWS_STORAGE_BUCKET_NAME=seaconnect-uat

# R2 endpoint: https://[account_id].r2.cloudflarestorage.com
AWS_S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# Optional: custom CDN domain mapped to the R2 bucket (e.g. cdn.seaconnect.app)
# Leave empty to use the R2 endpoint URL directly.
AWS_S3_CUSTOM_DOMAIN=

# Dev only — MinIO local override (replaces the above four vars in .env.dev)
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_STORAGE_BUCKET_NAME=seaconnect
# AWS_S3_ENDPOINT_URL=http://minio:9000

# ===========================================================================
# Email — Brevo SMTP (300 free emails/day, sufficient for UAT)
# In dev, Mailpit catches all email (EMAIL_HOST=localhost, EMAIL_PORT=1025).
# ===========================================================================

EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Brevo login email and SMTP key (Settings → SMTP & API → SMTP tab)
EMAIL_HOST_USER=your-brevo-login@example.com
EMAIL_HOST_PASSWORD=your-brevo-smtp-key

DEFAULT_FROM_EMAIL=noreply@seaconnect.eg

# ===========================================================================
# JWT (RS256) — ADR-009
# Generate keys:
#   openssl genrsa -out backend/keys/jwt_private.pem 2048
#   openssl rsa -in backend/keys/jwt_private.pem -pubout -out backend/keys/jwt_public.pem
# On Render, store keys as Secret Files at /etc/secrets/jwt_private.pem
# ===========================================================================

JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem

# ===========================================================================
# CORS — frontends allowed to call the API
# ===========================================================================

# Dev: Next.js web + admin (Docker Compose host ports)
CORS_ALLOWED_ORIGINS=http://localhost:3010,http://localhost:3011
# UAT: CORS_ALLOWED_ORIGINS=https://seaconnect-uat.vercel.app,https://seaconnect-uat-admin.vercel.app

# ===========================================================================
# Payment gateway — Fawry (ADR-007)
# Use sandbox values in dev/UAT; switch to production URL for prod.
# ===========================================================================

FAWRY_MERCHANT_CODE=sandbox_merchant
FAWRY_SECURITY_KEY=sandbox_key

# Staging: https://atfawry.fawrystaging.com
# Production: https://www.atfawry.com
FAWRY_BASE_URL=https://atfawry.fawrystaging.com

# ===========================================================================
# Firebase Cloud Messaging — push notifications (optional)
# Encode the downloaded service-account JSON:
#   base64 -w 0 firebase-service-account.json
# Then paste the result below. The app decodes it at startup.
# ===========================================================================

FIREBASE_CREDENTIALS_JSON=

# ===========================================================================
# SMS — Twilio (optional, not required for MVP)
# ===========================================================================

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===========================================================================
# AI / Vector search (ADR-019)
# Dev: Ollama local (nomic-embed-text 768-dim)
# UAT: OpenAI text-embedding-3-small (1536-dim)
# ===========================================================================

OLLAMA_BASE_URL=http://ollama:11434
OPENAI_API_KEY=

# ===========================================================================
# Observability
# ===========================================================================

# Sentry DSN — leave empty to disable Sentry (safe in dev)
SENTRY_DSN=

# Mixpanel project token — analytics event ingestion
MIXPANEL_TOKEN=

# Git commit SHA — injected by Render automatically; used in Sentry releases
GIT_COMMIT_SHA=local
